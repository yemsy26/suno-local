{
    "_doc": "Suno-Local v3.0 — config.json limpio",
    
    "ollama_model": "gemma2:latest",

    "rvc_model_path": "models/rvc/voz_propia.pth",
    "rvc_index_path": "models/rvc/voz_propia.index",
    "gallery_dir": "gallery",
    "temp_dir": "Z:/temp",
    "audio_backend": "acestep",

    "rvc_pitch_shift": 0,
    "rvc_f0_method": "rmvpe",
    "rvc_index_rate": 0.75,
    "rvc_filter_radius": 3,
    "rvc_protect": 0.45,
    "rvc_hop_length": 128,

    "mix_voice_volume_db": 12.0,
    "mix_beat_volume_db": 4.5,
    "target_lufs": -14.0,
    "sample_rate": 48000,

    "supervised_mode": false,
    "checkpoint_timeout_seconds": 600,
    "uvr5_segment_size": 128
}
